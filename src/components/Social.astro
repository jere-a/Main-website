---
interface Props {
  href: string;
  platform: string;
}

const { href, platform } = Astro.props;

const youtube = platform === "YT";
---

{
  youtube && (
  <a class="yt" title="Go and see my Youtube channel" href={href}><slot /></a>
  )
}

<style>
.yt {
  display: inline-flex;
  align-items: center;
  gap: 0.2em;
  padding: 0em 0.2em;

  background-color: rgba(183, 0, 0, 0.827);
  border-radius: 5px;
  color: white;
  text-decoration: underline;

  view-transition-name: yt;
  }
</style>
