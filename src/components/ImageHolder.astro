---
import { Picture } from 'astro:assets';
import '@/global.css';

interface Props {
	title: string;
	body?: string;
	src: ImageMetadata;
	alt?: string;
	class?: any;
	transitionName?: string;
}

const { class: className, src, title, body, alt, transitionName } = Astro.props;

const _altfunc = (): string => {
	if (alt !== undefined) return alt;
	else if (alt === undefined) return title;
	else return '';
};
---

<div class="card fade-transition" style={{ viewTransitionName: transitionName }}>
	<div>
		<Picture
			src={src}
			alt={_altfunc()}
			class={`image ${className}`}
			formats={['avif', 'webp']}
			quality={'medium'}
		/>
		<br />
		<h2 class="title">
			{title}
		</h2>
		{body !== undefined && <p class="body">{body}</p>}
	</div>
</div>

<style>
	.card {
		list-style: none;
		display: flex;
		background-color: #23262d;
		background-image: none;
		background-size: 400%;
		border-radius: 1rem;
		background-position: 100%;
		transition: background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
		position: relative;
		background: hsl(from var(--surface-3) h s l / 0.25);
		backdrop-filter: blur(25px);
		div {
			width: 100%;
			text-decoration: none;
			line-height: 1.4;
			padding: 0.8rem;
			border-radius: 8px;
			color: white;
			opacity: 0.8;
		}
		&::before {
			content: '';
			position: absolute;
			z-index: -1;
			inset: 0;
			border-radius: inherit;
			border: var(--border-width) solid transparent;
			background: linear-gradient(var(--border-1), var(--border-2)) border-box;
			mask:
				linear-gradient(black, black) border-box,
				linear-gradient(black, black) padding-box;
			mask-composite: subtract;
		}
	}
	.card:where(img, source) {
		width: 100%;
		height: auto;
		margin: auto;
		justify-content: center;
	}

	.image {
		border-radius: 8px;
	}

	h2 {
		padding: 5px;
		font-size: 1.25rem;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}
	p {
		margin-top: 0.5rem;
	}
</style>
