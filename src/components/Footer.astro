---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

interface Props {
	isCopyright?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = (await useTranslations(lang));

const { isCopyright = true } = Astro.props;

const copyrightText = `${t.footer.copyright} © 2024-${new Date().getFullYear()} Jere L`;
---

<footer id="main-footer">
	{
    isCopyright && ( <hacker-text>{copyrightText}</hacker-text> )
	}
</footer>

<style>
	footer {
		position: fixed;
		left: 0;
		bottom: 0.8rem;
		width: 100%;
		text-align: center;
	}
	footer p {
		margin-inline: auto;
	}
</style>

<script>
  import hackerText from '@/ts/hacker-text';

  let value: string | undefined;

  class HackerText extends HTMLElement {
    connectedCallback() {
      if (this) {
        const text = value ??= this.innerText;
        this.addEventListener('mouseover', () => {
            hackerText(this, text);
        })
      }
    }
  }

  customElements.define('hacker-text', HackerText);
</script>
