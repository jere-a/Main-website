---
import Layout from '@/layouts/Layout.astro';
import ImageHolder from '@/components/ImageHolder.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import Ghost from '../../data/images/Aamuinen usva.jpg';
import Sunflower from '../../data/images/auringon kukka 2.jpg';
import Big_root from '../../data/images/Iso kanto.jpg';
import NightBridgeWithLights from '../../data/images/Isompi silta pimeällä.jpg';
import WhiteLittleBridgeAtNight from '../../data/images/silta pimeällä.jpg';
import BlueSky from '../../data/images/sininen taivas.jpg';
import winterLandscape from '../../data/images/talvinen maisema 2.jpg';

const images: {
	src: ImageMetadata;
	title: string;
}[] = [
	{
		src: winterLandscape,
		title: 'Talvinen Maisema Sillalta.',
	},
	{
		src: Big_root,
		title: 'Iso Kanto.',
	},
	{
		src: BlueSky,
		title: 'Sininen Taivas.',
	},
	{
		src: Sunflower,
		title: 'Auringon kukka.',
	},
	{
		src: Ghost,
		title: 'Aamuinen usva.',
	},
	{
		src: NightBridgeWithLights,
		title: 'Värikäs silta pimeällä',
	},
	{
		src: WhiteLittleBridgeAtNight,
		title: 'Silta pimeällä',
	},
];
---

<Layout title={t.images.title} activeNav="kuvat">
	<h1 style={{ viewTransitionName: 'hero_text' }} class="text-gradient title fade-transition">
		{t.images.title}
	</h1>
	<p class="subtitle">{t.images.subtitle}</p>
	<ul role="list" class="image-card-grid">
		{
			images.map((image, i) => (
				<li>
					<ImageHolder src={image.src} title={image.title} transitionName={'card' + i} />
				</li>
			))
		}
	</ul>
</Layout>

<style>
	p.subtitle {
		margin-inline: auto;
		text-align: center;
		line-height: 1;
		margin-bottom: calc(var(--spacing) * 2);
		font-size: 1.2rem;
	}

	h1.title {
		line-height: 1;
		margin-bottom: calc((--spacing) * 4);
		font-size: 3.5rem;
		text-align: center;
		font-weight: var(--font-weight-bold);
	}

	.image-card-grid {
		--grid-min-col-size: 300px;

		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(var(--grid-min-col-size), 100%), 1fr));
		justify-items: center;
		gap: 0.5rem;
	}
</style>

<script>
	import { isHoliday } from '@/ts/global';
	import { $ } from '@/ts/jquery/basic';

	const observer = new IntersectionObserver(observerFn);
	function observerFn(entries: any) {
		for (const entry of entries) {
			entry.loading = 'eager';
		}
	}
	$('ul li picture img').each((e) => {
		if (e instanceof Element) {
			observer.observe(e);
		}
	});

	const textGradientEl = document.querySelector<HTMLElement>('.text-gradient');
	const pEl = document.querySelector<HTMLParagraphElement>('p');
	const holiday = await isHoliday([textGradientEl ?? undefined, pEl ?? undefined, '.navItem']);

	if (holiday.bool) {
		holiday.script;
	}
</script>
